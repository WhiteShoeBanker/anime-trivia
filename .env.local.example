# ── Supabase ─────────────────────────────────────────────────────────
# Project URL. Find at: Supabase dashboard → Project Settings → API → Project URL.
# Format: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-here.supabase.co

# Public (anon) JWT. Safe to ship to the browser. RLS enforces access.
# Find at: Supabase dashboard → Project Settings → API → anon / public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=paste-anon-key-here

# Service-role JWT. NEVER expose to the browser. Bypasses RLS.
# Find at: Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=paste-service-role-key-here

# ── Admin access ─────────────────────────────────────────────────────
# Comma-separated allowlist of admin email addresses (case-insensitive).
# Whitespace tolerated. Example: alice@example.com, bob@example.com
# optional — leave empty to disable admin access (all /admin routes return 404).
ADMIN_EMAILS=

# ── Cron auth ────────────────────────────────────────────────────────
# Shared secret used by Vercel Cron jobs to authenticate requests to
# /api/process-leagues, /api/expire-duels, /api/process-grand-prix, etc.
# Generate a long random string (e.g. `openssl rand -hex 32`).
# optional in local dev — required in any environment that runs the cron routes.
CRON_SECRET=
