{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(designmd *)",
      "Bash(design.md *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(tsc --noEmit:*)",
      "Bash(node --version:*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd:*)",
      "Bash(which *)",
      "Bash(curl -s *)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)",
      "Edit(.env*)",
      "Read(.env*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(vercel *)",
      "Bash(supabase *)",
      "Bash(npm run db:*)"
    ]
  }
}
